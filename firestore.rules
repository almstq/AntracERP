rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // True once a Super Admin has assigned a real role — i.e. NOT the self-registered
    // 'pending' placeholder. Gates all business-data reads/writes so a brand-new signup
    // (or anyone who finds the public URL and registers) cannot touch operational data
    // until an admin approves them. Self-read of one's own users/{uid} doc stays open
    // so the pending screen + auth bootstrap still work.
    function hasAssignedRole() {
      return isAuth() && getUserRole() != 'pending';
    }

    function isSuperAdmin() {
      return isAuth() && getUserRole() == 'super_admin';
    }

    function isGM() {
      return isAuth() && getUserRole() in ['gm', 'director', 'super_admin'];
    }

    function isSiteManager() {
      return isAuth() && getUserRole() in ['supervisor', 'gm', 'director', 'super_admin'];
    }

    function isMechanic() {
      return isAuth() && getUserRole() in ['mechanic', 'super_admin'];
    }

    function isProcurement() {
      return isAuth() && getUserRole() in ['proc_staff', 'gm', 'super_admin'];
    }

    function isFinance() {
      return isAuth() && getUserRole() in ['finance_wli', 'antrac_finance', 'super_admin'];
    }

    function isInventoryStaff() {
      return isAuth() && getUserRole() in ['inventory_staff', 'super_admin'];
    }

    function isWLIStaff() {
      return isAuth() && getUserRole() in ['operator', 'mechanic', 'supervisor', 'gm', 'proc_staff', 'finance_wli', 'inventory_staff', 'super_admin'];
    }

    // Any role that participates in a workflow (incl. HQ finance chain + MPL).
    // Coarse gate only — per-stage authority is enforced by the app transition tables.
    function isWorkflowParticipant() {
      return isAuth() && getUserRole() in [
        'operator', 'mechanic', 'supervisor', 'gm', 'proc_staff', 'finance_wli',
        'inventory_staff', 'antrac_finance', 'cfo', 'director', 'mpl_manager', 'super_admin'
      ];
    }

    // Orgs — read by all authenticated users, write by super admin only
    match /orgs/{orgId} {
      allow read: if hasAssignedRole();
      allow write: if isSuperAdmin();
    }

    // Unified role registry. All runtime role edits and SA-created roles live
    // under /roles; /customRoles and appConfig/roleOverrides remain readable as
    // migration fallback for older clients.
    match /roles/{roleId} {
      allow read: if hasAssignedRole();
      allow create, update, delete: if isSuperAdmin();
    }
    match /customRoles/{roleId} {
      allow read: if hasAssignedRole();
      allow create, update, delete: if isSuperAdmin();
    }
    match /appConfig/roleOverrides {
      allow read: if hasAssignedRole();
      allow write: if isSuperAdmin();
    }

    // Users — self read; new sign-ups self-register as 'pending'; only SA assigns roles
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isAuth() && request.auth.uid == userId
                    && request.resource.data.role == 'pending';
      allow update, delete: if isSuperAdmin();
    }

    // Sites — read by all, write by site manager+
    match /sites/{siteId} {
      allow read: if hasAssignedRole();
      allow create, update: if isSiteManager() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Staff — read by all, write by site manager+
    match /staff/{staffId} {
      allow read: if hasAssignedRole();
      allow create, update: if isSiteManager() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Assets — read by all, write by site manager+
    match /assets/{assetId} {
      allow read: if hasAssignedRole();
      allow create, update: if isSiteManager() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Tickets — operators raise; WLI staff act on them through the workflow.
    // Fine-grained stage gating is enforced in app logic (transition tables).
    match /tickets/{ticketId} {
      allow read: if hasAssignedRole();
      allow create: if isWLIStaff();
      allow update: if isWLIStaff();
      allow delete: if isSuperAdmin();
      // Timeline subcollection — append-only audit trail
      match /timeline/{eventId} {
        allow read: if hasAssignedRole();
        allow create: if isWLIStaff();
        allow update, delete: if false;
      }
    }

    // Purchase requests (created on_hold at mechanic diagnosis; advanced by proc/gm)
    match /purchaseRequests/{prId} {
      allow read: if hasAssignedRole();
      allow create: if isWLIStaff();
      allow update: if isWLIStaff();
      allow delete: if isSuperAdmin();
      match /timeline/{eventId} {
        allow read: if hasAssignedRole();
        allow create: if isWorkflowParticipant();
        allow update, delete: if false;
      }
    }

    // RFQs
    match /rfqs/{rfqId} {
      allow read: if hasAssignedRole();
      allow create, update: if isProcurement() || isGM();
      allow delete: if isSuperAdmin();
    }

    // Purchase orders (carry the 4-tier HQ payment chain → HQ roles must update)
    match /purchaseOrders/{poId} {
      allow read: if hasAssignedRole();
      allow create: if isWLIStaff();
      allow update: if isWorkflowParticipant();
      allow delete: if isSuperAdmin();
      match /timeline/{eventId} {
        allow read: if hasAssignedRole();
        allow create: if isWorkflowParticipant();
        allow update, delete: if false;
      }
    }

    // Stores register — named stock-holding places attached to sites
    match /stores/{storeId} {
      allow read: if hasAssignedRole();
      allow create, update: if isSiteManager() || isInventoryStaff() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Inventory items (catalog — no quantity)
    match /inventoryItems/{itemId} {
      allow read: if hasAssignedRole();
      allow write: if isProcurement() || isSiteManager() || isInventoryStaff() || isSuperAdmin();
    }

    // Stock balances — quantity per item × store
    match /stockBalances/{balanceId} {
      allow read: if hasAssignedRole();
      allow write: if isProcurement() || isSiteManager() || isInventoryStaff() || isSuperAdmin();
    }

    // Stock movements — append-only ledger
    match /stockMovements/{movementId} {
      allow read: if hasAssignedRole();
      allow create: if isSiteManager() || isProcurement() || isInventoryStaff() || isSuperAdmin();
      allow update, delete: if false;
    }

    // Stock transfers — logistics (store → store)
    match /stockTransfers/{transferId} {
      allow read: if hasAssignedRole();
      allow create: if isInventoryStaff() || isSiteManager() || isSuperAdmin();
      allow update: if isInventoryStaff() || isSiteManager() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Sequence counters — written by inventory service
    match /_sequences/{seqId} {
      allow read, write: if hasAssignedRole();
    }

    // Central Document Registry Index
    match /registryIndex/{docId} {
      allow read, write: if hasAssignedRole();
    }

    // Customers
    match /customers/{customerId} {
      allow read: if hasAssignedRole();
      allow write: if isGM() || isSuperAdmin();
    }

    // CRM enquiries, quotations, work orders, invoices, and payments.
    // The app collection names are plural nouns; keep rules aligned with services/crm.ts.
    match /enquiries/{enquiryId} {
      allow read: if hasAssignedRole();
      allow write: if isGM() || isSuperAdmin();
    }

    match /quotations/{quotationId} {
      allow read: if hasAssignedRole();
      allow write: if isGM() || isSuperAdmin();
    }

    match /workOrders/{workOrderId} {
      allow read: if hasAssignedRole();
      allow write: if isGM() || isSuperAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if hasAssignedRole();
      allow write: if isGM() || isFinance() || isSuperAdmin();
    }

    match /payments/{paymentId} {
      allow read: if hasAssignedRole();
      allow create: if isGM() || isFinance() || isSuperAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // Notifications — user-specific
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // Audit events — append only
    match /auditEvents/{eventId} {
      allow read: if hasAssignedRole();
      allow create: if hasAssignedRole();
      allow update, delete: if false;
    }

    // System activity log — read by GM+/SA; written by workflow engine (any assigned role);
    // immutable (no update/delete) so it serves as a tamper-evident audit trail.
    match /activityLog/{logId} {
      allow read: if isGM() || isSuperAdmin();
      allow create: if hasAssignedRole();
      allow update, delete: if false;
    }

    // FollowMe vessel-tracking cache — written ONLY by the syncFollowMe Cloud
    // Function (admin SDK bypasses rules). Clients read the cache; never write.
    match /followmeCache/{vesselId} {
      allow read: if hasAssignedRole();
      allow write: if false;
    }
    match /followmeMeta/{docId} {
      allow read: if hasAssignedRole();
      allow write: if false;
    }

    // Fuel/water requests (WLI↔MPL; supervisor, inventory, gm, mpl_manager, director act)
    match /fuelRequests/{requestId} {
      allow read: if hasAssignedRole();
      allow create: if isWLIStaff();
      allow update: if isWorkflowParticipant();
      allow delete: if isSuperAdmin();
      match /timeline/{eventId} {
        allow read: if hasAssignedRole();
        allow create: if isWorkflowParticipant();
        allow update, delete: if false;
      }
    }

    // Suppliers — read by all auth; managed by procurement/GM
    match /suppliers/{supplierId} {
      allow read: if hasAssignedRole();
      allow write: if isProcurement() || isGM() || isSuperAdmin();
    }

    // WLI inventory balances (fuel/water) — deducted on fuel request closure
    match /inventoryBalances/{balanceId} {
      allow read: if hasAssignedRole();
      allow write: if isWorkflowParticipant();
    }

    // Top-level workflow notifications — recipient (by role or uid) can read/mark-read.
    // Super Admin can read/update all notifications so they can manage inboxes while
    // impersonating other roles.
    match /notifications/{notifId} {
      allow read: if isSuperAdmin() || (isAuth() && (resource.data.recipientRole == getUserRole() || resource.data.recipientId == request.auth.uid));
      allow create: if isWorkflowParticipant();
      allow update: if isSuperAdmin() || (isAuth() && (resource.data.recipientRole == getUserRole() || resource.data.recipientId == request.auth.uid));
      allow delete: if isSuperAdmin();
    }

    // Document Vault — all authenticated users can read; create on upload; delete by uploader or admin
    match /documents/{docId} {
      allow read: if hasAssignedRole();
      allow create: if hasAssignedRole();
      allow delete: if isSuperAdmin() || (hasAssignedRole() && resource.data.uploadedById == request.auth.uid);
      allow update: if false;
    }

    // AI tasks
    match /aiTasks/{taskId} {
      allow read: if hasAssignedRole();
      allow create: if hasAssignedRole();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Machine deployments — revenue terms on hire (creating one also flips the
    // asset to deployed, so the deployer must be a site manager / GM / SA)
    match /deployments/{depId} {
      allow read: if hasAssignedRole();
      allow create, update: if isSiteManager() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Deployment revenue (lump figures, e.g. from Finance/CFO)
    match /deploymentRevenue/{revId} {
      allow read: if hasAssignedRole();
      allow create, update: if isGM() || isFinance() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
