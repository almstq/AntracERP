# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project values
# Get these from: https://console.firebase.google.com → Project Settings → General → Your apps

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Maps + weather (optional — app degrades gracefully without them)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
VITE_OPENWEATHER_API_KEY=your_openweather_key_here

# Gemini AI (optional — powers advisory briefs & diagnosis hints; app runs fine without it)
# Get a key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_key_here
# Model is optional — defaults to gemini-2.5-flash in code. Only override if that
# default ever goes off the free tier. Free-tier-verified: gemini-2.5-flash,
# gemini-2.5-flash-lite, gemini-flash-latest. (The gemini-2.0-flash family = limit:0.)
VITE_GEMINI_MODEL=gemini-2.5-flash
